---
import Layout from '../layouts/BaseLayout.astro';
---
<Layout>
  <section style="padding: 5rem 2rem; text-align: center;">
    <h2 style="font-size: 2.25rem; margin-bottom: 1rem;">Book Your Free Consultation</h2>
    <p style="font-size: 1.125rem; color: #444; max-width: 600px; margin: 0 auto 2rem;">
      Tell us about your idea or project. We'll get back to you within 24 hours at <strong>support@nextnode.ventures</strong>.
    </p>

    <form 
      name="consultation" 
      method="POST" 
      data-netlify="true" 
      style="
        display: flex;
        flex-direction: column;
        gap: 1rem;
        max-width: 500px;
        margin: 0 auto;
        text-align: left;
      "
    >
      <input type="hidden" name="form-name" value="consultation" />
      
      <input 
        name="name" 
        placeholder="Your Name" 
        required 
        style="padding: 0.75rem; border: 1px solid #ccc; border-radius: 6px;" 
      />
      
      <input 
        name="email" 
        type="email" 
        placeholder="Email" 
        required 
        style="padding: 0.75rem; border: 1px solid #ccc; border-radius: 6px;" 
      />
      
      <textarea 
        name="message" 
        placeholder="Tell us about your idea..." 
        rows="5"
        style="padding: 0.75rem; border: 1px solid #ccc; border-radius: 6px;"
      ></textarea>
      
      <button 
        type="submit" 
        style="
          background: linear-gradient(90deg, #ff1884, #ffac27);
          color: white;
          padding: 0.85rem 1.5rem;
          border: none;
          border-radius: 6px;
          font-weight: 600;
          cursor: pointer;
          transition: transform 0.2s ease;
        "
      >
        Submit
      </button>
    </form>
  </section>
</Layout>
