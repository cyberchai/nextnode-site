---
import Layout from '../layouts/BaseLayout.astro';
---
<Layout>
  <section style="padding: 5rem 2rem; text-align: center;">
    <h2 style="font-size: 2.25rem; margin-bottom: 1rem;">Contact Us</h2>
    <p style="font-size: 1.125rem; color: #444; margin-bottom: 2rem;">
      We'd love to hear from you. Reach out anytime.
    </p>

    <div style="display: flex; flex-direction: column; gap: 1rem; align-items: center; font-size: 1rem;">
      <div>
        <strong>Email:</strong> <a href="mailto:support@nextnode.ventures" style="color: #7f5af0; text-decoration: none;">support@nextnode.ventures</a>
      </div>
      <div>
        <strong>LinkedIn:</strong> <a href="https://www.linkedin.com/in/chaira-harder/" target="_blank" style="color: #7f5af0; text-decoration: none;">chairaharder</a>
      </div>
    </div>
  </section>
</Layout>
