---
import { TextSection } from '@components/odyssey-theme';
import Layout from '../../layouts/Page.astro';
import FAQHeroSection from '../../components/sections/heros/FAQHeroSection.astro';

const seo = {
  title: 'FAQ Page | NextNode Studio',
  description: 'Frequently Asked Questions about NextNode Studio, our services, and how we can help you build your next project.',
};

const faqs = [
  {
    q: 'Are you legally eligible to do business in the US and Canada?',
    a: 'Yes. All contracts are made through NextNode LLC, a registered US business. We are also Canadian, so we serve clients across North America. All financial and legal responsibilities are handled through these entities.',
  },
  {
    q: 'Do you work with solo creatives like artists, writers, or musicians?',
    a: 'Yes. We regularly help individual artists, writers, and musicians bring their work online. Whether you want to showcase a portfolio, publish your writing, or share your music, we can build a clean, thoughtfully designed site on WordPress or a custom platform. No technical knowledge is required on your part.',
  },
  {
    q: 'How does your pricing work?',
    a: 'Pricing depends on the scope and complexity of each project. We offer both hourly and flat rate options. As a reference point, a simple website typically starts around $500. We are glad to talk through the details during a free consultation, and you can use our <a href="/company/costcalculator">cost calculator</a> for a rough estimate.',
  },
  {
    q: 'What kind of support do you offer after launch?',
    a: 'We offer both ongoing maintenance packages and one time handoffs with full documentation. Some clients prefer that we manage everything, while others take over after a clean launch. We are happy to do either, or a combination of the two.',
  },
  {
    q: 'Do you work with solo founders or early stage startups?',
    a: 'Yes. We enjoy working with founders at the earliest stages and can help you reach an MVP or build a proof of concept, with flexibility around scope and budget.',
  },
  {
    q: 'Do you collaborate on civic tech or public interest projects?',
    a: 'Yes, and we would like to do more of this work. If your project supports communities, promotes equity, or improves access to public services, we would be glad to hear about it.',
  },
  {
    q: "I'm interested in learning with you. Do you offer internships?",
    a: "We run a one month internship each July, and the next one is in July 2026. The program is design focused, so a technical background is not required. We mainly look for storytelling ability, a strong sense of design, and creativity. If that fits you, send us a note about yourself and your work.",
  },
];
---

<Layout {seo}>
  <FAQHeroSection />

  <TextSection>
    <div class="faq-accordion">
      {faqs.map((faq) => (
        <details class="faq-item">
          <summary class="faq-summary">
            <h3 class="faq-question">{faq.q}</h3>
            <svg class="faq-icon" viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
              <path fill="currentColor" d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z" />
            </svg>
          </summary>
          <div class="faq-answer">
            <div class="faq-answer__inner">
              <p set:html={faq.a} />
            </div>
          </div>
        </details>
      ))}
    </div>
  </TextSection>
</Layout>

<script>
  const items = document.querySelectorAll<HTMLDetailsElement>('.faq-item');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  items.forEach((item) => {
    const summary = item.querySelector('summary');
    const answer = item.querySelector<HTMLElement>('.faq-answer');
    if (!summary || !answer) return;

    summary.addEventListener('click', (e) => {
      e.preventDefault();

      // No-frills toggle when the user prefers reduced motion.
      if (reduceMotion) {
        item.open = !item.open;
        return;
      }

      // Ignore clicks mid-transition so rapid toggling can't desync state.
      if (item.dataset.animating) return;
      item.dataset.animating = 'true';

      const onEnd = (ev: TransitionEvent) => {
        if (ev.propertyName !== 'max-height') return;
        answer.removeEventListener('transitionend', onEnd);
        answer.style.maxHeight = '';
        delete item.dataset.animating;
        if (!item.open) item.open = false;
      };

      if (item.open) {
        // Collapse: lock current height, reflow, then animate to 0.
        answer.style.maxHeight = `${answer.scrollHeight}px`;
        void answer.offsetHeight;
        answer.addEventListener('transitionend', (ev) => {
          if ((ev as TransitionEvent).propertyName !== 'max-height') return;
          item.open = false;
          answer.style.maxHeight = '';
          delete item.dataset.animating;
        }, { once: true });
        requestAnimationFrame(() => { answer.style.maxHeight = '0px'; });
      } else {
        // Expand: render content, start at 0, then animate to its full height.
        item.open = true;
        answer.style.maxHeight = '0px';
        void answer.offsetHeight;
        answer.addEventListener('transitionend', onEnd, { once: true });
        requestAnimationFrame(() => { answer.style.maxHeight = `${answer.scrollHeight}px`; });
      }
    });
  });
</script>

<style>
  /* Accordion adapted from a dark reference design, inverted for the site's
     light theme: minimal rows, hairline separators, a forward arrow that
     turns downward on open, and a brand-violet accent. */
  .faq-accordion {
    --faq-line: color-mix(in srgb, var(--theme-on-bg, #000) 12%, transparent);
    --faq-accent: #5b2be0;
    max-width: 820px;
    margin-inline: auto;
    border-top: 1px solid var(--faq-line);
  }

  .faq-item {
    border-bottom: 1px solid var(--faq-line);
  }

  .faq-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem 0.25rem;
    cursor: pointer;
    list-style: none;
    transition: color var(--theme-transition, 0.2s ease);
  }
  .faq-summary::-webkit-details-marker {
    display: none;
  }
  .faq-summary:hover .faq-question,
  .faq-item[open] .faq-question {
    color: var(--faq-accent);
  }

  .faq-question {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--theme-on-bg, #111);
    transition: color var(--theme-transition, 0.2s ease);
  }

  .faq-icon {
    flex-shrink: 0;
    color: var(--faq-accent);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .faq-item[open] .faq-icon {
    transform: rotate(90deg);
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .faq-item[open] .faq-answer {
    max-height: none;
  }

  .faq-answer__inner {
    padding: 0 0.25rem 1.5rem;
  }
  .faq-answer__inner :global(p) {
    margin: 0;
    max-width: 68ch;
    font-size: 1.05rem;
    line-height: 1.7;
    color: color-mix(in srgb, var(--theme-on-bg, #000) 78%, transparent);
  }
  .faq-answer__inner :global(a) {
    color: var(--faq-accent);
    text-underline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-icon,
    .faq-answer,
    .faq-summary,
    .faq-question {
      transition: none;
    }
  }
</style>
