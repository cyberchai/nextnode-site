---
import Layout from '../layouts/BaseLayout.astro';
---
<Layout>
  <section style="padding: 5rem 2rem; text-align: center;">
    <h2 style="font-size: 2.25rem; margin-bottom: 1rem;">Our Services</h2>
    <p style="font-size: 1.125rem; color: #444; max-width: 600px; margin: 0 auto 2.5rem;">
      We help founders and teams go from idea to impact with modern tools and fast turnarounds.
    </p>

    <ul style="
      list-style: none;
      padding: 0;
      margin: 0 auto;
      max-width: 600px;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      font-size: 1.05rem;
      color: #222;
    ">
      <li>Custom Web & Mobile App Development</li>
      <li>Startup Tech Stack Consulting</li>
      <li>Technical Founding Support</li>
      <li>Rapid MVP & Prototyping</li>
    </ul>
  </section>
</Layout>
